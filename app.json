{
  "expo": {
    "name": "EcommerceApp",
    "slug": "EcommerceApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ecommerceapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ecommerce.app"
    },
    "android": {
      "package": "com.ecommerce.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#FF6B35"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EcommerceApp to access your photos.",
          "cameraPermission": "Allow EcommerceApp to use your camera."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "http://192.168.1.220:5001/api",
      "eas": {
        "projectId": "6959f7c8-c278-4cc4-bcc9-f97293fe8b74"
      }
    },
    "owner": "saiganesh12345"
  }
}
