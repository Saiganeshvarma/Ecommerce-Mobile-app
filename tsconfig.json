{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@api/*": [
        "./src/api/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@screens/*": [
        "./src/screens/*"
      ],
      "@navigation/*": [
        "./src/navigation/*"
      ],
      "@redux/*": [
        "./src/redux/*"
      ],
      "@hooks/*": [
        "./src/hooks/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@theme/*": [
        "./src/theme/*"
      ],
      "@constants/*": [
        "./src/constants/*"
      ],
      "@models/*": [
        "./src/models/*"
      ],
      "@validations/*": [
        "./src/validations/*"
      ],
      "@services/*": [
        "./src/services/*"
      ],
      "@assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/types/**/*.d.ts",
    "index.ts"
  ],
  "exclude": [
    "components",
    "hooks",
    "constants",
    "node_modules"
  ]
}
